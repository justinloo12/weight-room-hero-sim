# Copy this file to .env and fill in real values, or export the variables
# in your shell before running the scripts. Never commit a real .env.

# The Odds API key (https://the-odds-api.com) — required by dashboard.py
# to fetch home-run prop odds from sportsbooks.
ODDS_API_KEY=your_odds_api_key_here

# Discord webhook URL — required by alert_homers.py to post live HR alerts.
# In GitHub Actions this is provided via the DISCORD_WEBHOOK_URL repo secret.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook_url
